:80 {
    encode zstd gzip

    log {
        output stdout
        format json
    }

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    handle /ai {
        redir /ai/ 308
    }

    handle_path /ai/* {
        reverse_proxy ai:8000
    }

    @spring path /api /api/* /v3/api-docs* /swagger /swagger/* /swagger-ui/* /actuator/*
    handle @spring {
        reverse_proxy app:8080
    }

    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
